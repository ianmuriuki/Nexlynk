# ─── Copy this file to .env.local ───────────────────────────────────
# .env.local is gitignored and never committed

# Your backend URL — the Vite proxy forwards /api → this
# In dev this is your Express server (default port 3000)
VITE_API_BASE_URL=http://localhost:5000

# App display name (used in page titles etc.)
VITE_APP_NAME=Nexlynk